# Vercel Blob storage (Storage tab -> Blob -> Create -> copy the read/write token,
# or run `vercel env pull` after linking a Blob store to this project).
BLOB_READ_WRITE_TOKEN=

# Which provider classifies images: "anthropic" (default) or "openai".
AI_PROVIDER=anthropic

# Password gating the in-app "Connect" flow (see README) that lets you paste a provider API key
# through the UI instead of only via env vars below. Required for that flow to work at all - pick
# a long random value, e.g. `openssl rand -hex 32`.
ADMIN_SECRET=

# Optional: set the key matching AI_PROVIDER here instead of/in addition to connecting one via the
# UI. An env var here always takes priority over a key connected through the app.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional overrides.
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# OPENAI_MODEL=gpt-4o-mini
# CLASSIFICATION_THRESHOLD=0.7
# REEVALUATION_MARGIN=0.15
# MAX_REEVALUATIONS_PER_RUN=12
# MAX_SWEEP_PER_RUN=8
