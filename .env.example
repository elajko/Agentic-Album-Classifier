# Vercel Blob storage (Storage tab -> Blob -> Create -> copy the read/write token,
# or run `vercel env pull` after linking a Blob store to this project).
BLOB_READ_WRITE_TOKEN=

# Which provider classifies images: "anthropic" (default) or "openai".
AI_PROVIDER=anthropic

# Only the key matching AI_PROVIDER needs to be set.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional overrides.
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# OPENAI_MODEL=gpt-4o-mini
# CLASSIFICATION_THRESHOLD=0.7
# REEVALUATION_MARGIN=0.15
# MAX_REEVALUATIONS_PER_RUN=12
